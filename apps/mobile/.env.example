# ============================================================
#  BrandReel — FRONTEND .env  (Expo / React Native)
# ------------------------------------------------------------
#  CARA PAKAI:
#  1. Salin file ini menjadi ".env" di folder aplikasi Expo (brandreel-app)
#  2. Ganti nilainya sesuai alamat backend-mu
#
#  ATURAN PENTING:
#  - Variabel yang boleh dibaca aplikasi HARUS diawali "EXPO_PUBLIC_".
#  - JANGAN pernah menaruh SECRET di sini (kunci API, client secret, dll).
#    Semua secret hidup di BACKEND. Frontend hanya tahu ALAMAT backend.
# ============================================================

# Alamat backend yang dipanggil aplikasi.
#   lokal  : http://localhost:3000
#   online : https://xxx.onrender.com
EXPO_PUBLIC_API_URL=http://localhost:3000            # [WAJIB]

# Skema deep-link untuk menangkap balikan OAuth di HP (iOS/Android).
# Samakan dengan "scheme" di app.json (mis. "brandreel").
EXPO_PUBLIC_APP_SCHEME=brandreel                     # [WAJIB]

# (Opsional) Pemantauan error sisi klien.
EXPO_PUBLIC_SENTRY_DSN=                              # [OPSIONAL]

# (Opsional) Flag lingkungan untuk membedakan build.
EXPO_PUBLIC_ENV=development                          # development | production  [OPSIONAL]
