# ============================================================
#  BrandReel — BACKEND .env  (Node + TypeScript + Prisma + Neon)
# ------------------------------------------------------------
#  CARA PAKAI:
#  1. Salin file ini menjadi ".env"  (tanpa ".example")
#  2. Ganti tiap "GANTI_..." dengan nilai asli
#  3. JANGAN commit file .env ke Git (sudah diabaikan .gitignore)
#  4. Saat deploy ke Render: isi nilai-nilai ini di dashboard
#     Render > Environment, BUKAN dengan mengunggah file .env
#  Keterangan:  [WAJIB] harus diisi  |  [OPSIONAL] boleh dikosongkan dulu
# ============================================================

# ---------- DASAR APLIKASI ----------
NODE_ENV=development                       # development | production   [WAJIB]
PORT=3000                                  # pintu server lokal          [WAJIB]
APP_BASE_URL=http://localhost:3000         # alamat backend; saat online: https://xxx.onrender.com  [WAJIB]
WEB_APP_URL=http://localhost:8081          # alamat frontend web (untuk CORS)  [WAJIB]

# ---------- DATABASE (Neon PostgreSQL) ----------
# Ambil dari dashboard Neon > Connection string (pilih "Pooled" untuk aplikasi)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/brandreel?sslmode=require   # [WAJIB]
# Prisma butuh koneksi langsung (non-pooled) untuk migrasi:
DIRECT_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/brandreel?sslmode=require            # [WAJIB]

# ---------- REDIS (antrean BullMQ untuk publish & insights) ----------
# Lokal: install Redis / pakai Upstash gratis. Render: buat Redis instance.
REDIS_URL=redis://localhost:6379           # [WAJIB untuk fitur posting & insights]

# ---------- KEAMANAN / SESI ----------
SESSION_SIGNING_KEY=GANTI_teks_acak_panjang_min_32_karakter     # kunci tanda-tangan sesi login  [WAJIB]
TOKEN_ENCRYPTION_KEY=GANTI_teks_acak_panjang_min_32_karakter    # kunci enkripsi token platform  [WAJIB]
# Tips membuat nilai acak: jalankan di terminal ->  openssl rand -base64 48

# ---------- AI: CLAUDE (Anthropic) ----------
# Dari https://console.anthropic.com  (perlu saldo/billing aktif)
ANTHROPIC_API_KEY=sk-ant-GANTI_kunci_anthropic       # [WAJIB]
ANTHROPIC_MODEL=claude-sonnet-4-5                     # [OPSIONAL]

# ---------- AI: GOOGLE VEO (pembuat video) ----------
# Via Gemini API: https://aistudio.google.com/apikey
GEMINI_API_KEY=GANTI_kunci_gemini                    # [WAJIB kalau pakai Veo via Gemini]
VEO_MODEL=veo3.1-fast                                 # [OPSIONAL]
# --- ATAU via Vertex AI (skala besar), isi ini sebagai ganti GEMINI_API_KEY: ---
GOOGLE_PROJECT_ID=                                    # [OPSIONAL]
GOOGLE_APPLICATION_CREDENTIALS=                       # path file service-account.json  [OPSIONAL]

# ---------- GUDANG FILE (Object Storage untuk video) ----------
# Pilih SALAH SATU. Contoh di bawah: Cloudflare R2 / AWS S3 (kompatibel S3).
STORAGE_BUCKET=brandreel-media                        # [WAJIB]
STORAGE_ENDPOINT=https://xxx.r2.cloudflarestorage.com # kosongkan jika AWS S3 murni  [OPSIONAL]
STORAGE_REGION=auto                                   # mis. auto (R2) / ap-southeast-1 (S3)  [WAJIB]
STORAGE_ACCESS_KEY_ID=GANTI                           # [WAJIB]
STORAGE_SECRET_ACCESS_KEY=GANTI                       # [WAJIB]
CDN_BASE_URL=https://media.brandreel.com              # alamat publik file  [WAJIB]

# ============================================================
#  OAUTH PLATFORM SOSIAL MEDIA
#  Redirect URI yang didaftarkan di tiap portal:
#    lokal :  http://localhost:3000/auth/<platform>/callback
#    online:  https://xxx.onrender.com/auth/<platform>/callback
#  Isi HANYA platform yang sudah kamu daftarkan; sisanya biarkan kosong dulu.
# ============================================================

# ---------- TikTok ----------  https://developers.tiktok.com
TIKTOK_CLIENT_KEY=GANTI                               # [WAJIB untuk TikTok]
TIKTOK_CLIENT_SECRET=GANTI                            # [WAJIB untuk TikTok]

# ---------- Meta: Instagram + Facebook ----------  https://developers.facebook.com
META_APP_ID=GANTI                                     # [WAJIB untuk IG/FB]
META_APP_SECRET=GANTI                                 # [WAJIB untuk IG/FB]

# ---------- Google: YouTube ----------  https://console.cloud.google.com
GOOGLE_CLIENT_ID=GANTI                                # [WAJIB untuk YouTube]
GOOGLE_CLIENT_SECRET=GANTI                            # [WAJIB untuk YouTube]

# ---------- LinkedIn ----------  https://www.linkedin.com/developers
LINKEDIN_CLIENT_ID=GANTI                              # [OPSIONAL]
LINKEDIN_CLIENT_SECRET=GANTI                          # [OPSIONAL]

# ---------- X (Twitter) ----------  https://developer.x.com  (posting perlu tier berbayar)
X_CLIENT_ID=GANTI                                     # [OPSIONAL]
X_CLIENT_SECRET=GANTI                                 # [OPSIONAL]

# ---------- Verifikasi Webhook (opsional per platform) ----------
META_WEBHOOK_VERIFY_TOKEN=GANTI_teks_bebas            # [OPSIONAL]

# ---------- Pemantauan error (opsional) ----------
SENTRY_DSN=                                           # [OPSIONAL]  https://sentry.io
